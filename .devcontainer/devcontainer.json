{
    "name": "IB Algo Trade Dev",
    "build": {
        "dockerfile": "Dockerfile",
        "context": ".",
        "args": {
            "GIT_USER_NAME": "xiahualiu",
            "GIT_USER_EMAIL": "49677912+xiahualiu@users.noreply.github.com"
        }
    },
    "workspaceFolder": "/home/ubuntu/",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-vscode.cmake-tools",
                "llvm-vs-code-extensions.vscode-clangd",
                "ms-python.python",
                "ms-python.debugpy",
                "ms-python.black-formatter",
                "ms-python.mypy-type-checker",
                "ms-python.pylance",
                "anthropic.claude-code"
            ],
            "settings": {
                "cmake.generator": "Ninja",
                "cmake.buildDirectory": "${workspaceFolder}/build"
            }
        }
    },
    "remoteUser": "ubuntu",
    "mounts": [
        "source=/mnt/raid0/ib-home,target=/home/ubuntu,type=bind"
    ],
    "runArgs": [
        "--privileged",
        "--shm-size=16gb",
        "--name",
        "ib-algo-trade",
        "--add-host",
        "host.docker.internal:host-gateway",
        "--env-file",
        "${localWorkspaceFolder}/.env"
    ]
}
